<?xml version="1.0" encoding="utf-8"?>
<style xmlns="http://purl.org/net/xbiblio/csl" class="in-text" version="1.0.2" default-locale="en-US" demote-non-dropping-particle="sort-only" page-range-format="expanded">
  <info>
    <title>Journal of Integrative Agriculture (JIA, custom)</title>
    <id></id>
    <link href="http://" rel="self"/>
    <category citation-format="author-date"/>
    <category field="biology"/>
    <issn>2095-3119</issn>
    <summary>Custom CSL style for Journal of Integrative Agriculture based on recent JIA reference examples and the author guide. Author-date citations; full journal titles; bibliography as: Author A, Author B. Year. Title. Journal, volume, pages/article number.</summary>
    <updated>2026-06-06T00:00:00+00:00</updated>
    <rights license="http://creativecommons.org/licenses/by-sa/3.0/">This work is licensed under a Creative Commons Attribution-ShareAlike 3.0 License</rights>
  </info>

  <locale xml:lang="en">
    <terms>
      <term name="et-al">et al.</term>
      <term name="editor" form="short">ed.</term>
      <term name="editor" form="short" plural="true">eds.</term>
      <term name="accessed">accessed</term>
      <term name="available at">Available at</term>
    </terms>
  </locale>

  <macro name="author-bib">
    <names variable="author">
      <name name-as-sort-order="all" sort-separator=" " initialize-with=" " delimiter=", " delimiter-precedes-last="never"/>
      <substitute>
        <names variable="editor">
          <name name-as-sort-order="all" sort-separator=" " initialize-with=" " delimiter=", " delimiter-precedes-last="never"/>
        </names>
        <names variable="translator">
          <name name-as-sort-order="all" sort-separator=" " initialize-with=" " delimiter=", " delimiter-precedes-last="never"/>
        </names>
        <text variable="title"/>
      </substitute>
    </names>
  </macro>

  <macro name="author-cite">
    <names variable="author">
      <name form="short" and="text" delimiter=", " delimiter-precedes-last="never" initialize-with=" ">
        <et-al font-style="italic"/>
      </name>
      <substitute>
        <names variable="editor">
          <name form="short" and="text" delimiter=", " delimiter-precedes-last="never" initialize-with=" ">
        <et-al font-style="italic"/>
      </name>
        </names>
        <text variable="title" form="short"/>
      </substitute>
    </names>
  </macro>

  <macro name="year">
    <choose>
      <if variable="issued">
        <date variable="issued">
          <date-part name="year"/>
        </date>
      </if>
      <else>
        <text term="no date" form="short"/>
      </else>
    </choose>
  </macro>

  <macro name="year-cite">
    <choose>
      <if variable="issued">
        <date variable="issued">
          <date-part name="year"/>
        </date>
      </if>
      <else>
        <text term="no date" form="short"/>
      </else>
    </choose>
  </macro>

  <macro name="title">
    <text variable="title"/>
  </macro>

  <macro name="journal-container">
    <group suffix=".">
      <text variable="container-title"/>
      <text variable="volume" prefix=", "/>
      <choose>
        <if variable="page">
          <text variable="page" prefix=", "/>
        </if>
        <else-if variable="article-number">
          <text variable="article-number" prefix=", "/>
        </else-if>
      </choose>
    </group>
  </macro>

  <macro name="book-container">
    <group suffix=".">
      <text variable="publisher"/>
      <text variable="publisher-place" prefix=", "/>
    </group>
  </macro>

  <macro name="editor-in-book">
    <names variable="editor">
      <name name-as-sort-order="all" sort-separator=" " initialize-with=" " delimiter=", " delimiter-precedes-last="never"/>
      <label form="short" prefix=", " suffix="." text-case="lowercase"/>
    </names>
  </macro>

  <macro name="access">
    <choose>
      <if variable="URL">
        <group>
          <choose>
            <if variable="accessed">
              <group prefix=" [" suffix="]">
                <text term="accessed" text-case="capitalize-first" suffix=" "/>
                <date variable="accessed">
                  <date-part name="day" suffix=" "/>
                  <date-part name="month" form="long" suffix=" "/>
                  <date-part name="year"/>
                </date>
              </group>
            </if>
          </choose>
          <text term="available at" prefix=". " suffix=": "/>
          <text variable="URL"/>
        </group>
      </if>
    </choose>
  </macro>

  <macro name="doi-or-url">
    <choose>
      <if variable="DOI">
        <text variable="DOI" prefix=" doi: "/>
      </if>
      <else-if variable="URL">
        <text variable="URL" prefix=" Available at: "/>
      </else-if>
    </choose>
  </macro>

  <citation et-al-min="3" et-al-use-first="1" disambiguate-add-year-suffix="true" disambiguate-add-givenname="true" givenname-disambiguation-rule="primary-name-with-initials">
    <sort>
      <key macro="year-cite"/>
      <key macro="author-cite"/>
    </sort>
    <layout prefix="(" suffix=")" delimiter="; ">
      <group delimiter=" ">
        <text macro="author-cite"/>
        <text macro="year-cite"/>
      </group>
    </layout>
  </citation>

  <bibliography et-al-min="21" et-al-use-first="20" hanging-indent="true" entry-spacing="0" line-spacing="1">
    <sort>
      <key macro="author-bib"/>
      <key macro="year"/>
      <key variable="title"/>
    </sort>
    <layout>
      <choose>
        <if type="article-journal article-magazine article-newspaper" match="any">
          <group delimiter=". ">
            <text macro="author-bib"/>
            <text macro="year"/>
            <text macro="title"/>
          </group>
          <text macro="journal-container" prefix=". "/>
        </if>
        <else-if type="chapter paper-conference" match="any">
          <group delimiter=". ">
            <text macro="author-bib"/>
            <text macro="year"/>
            <text macro="title"/>
          </group>
          <group prefix=". In: " delimiter=". ">
            <text macro="editor-in-book"/>
            <text variable="container-title"/>
            <text macro="book-container"/>
          </group>
          <text variable="page" prefix=" pp. " suffix="."/>
        </else-if>
        <else-if type="book" match="any">
          <group delimiter=". " suffix=".">
            <text macro="author-bib"/>
            <text macro="year"/>
            <text variable="title"/>
            <text macro="book-container"/>
          </group>
        </else-if>
        <else-if type="thesis" match="any">
          <group delimiter=". " suffix=".">
            <text macro="author-bib"/>
            <text macro="year"/>
            <text macro="title"/>
            <text variable="genre"/>
            <text variable="publisher"/>
            <text variable="publisher-place"/>
          </group>
        </else-if>
        <else-if type="report" match="any">
          <group delimiter=". " suffix=".">
            <text macro="author-bib"/>
            <text macro="year"/>
            <text macro="title"/>
            <text variable="publisher"/>
            <text variable="publisher-place"/>
          </group>
        </else-if>
        <else-if type="dataset" match="any">
          <text value="[dataset] "/>
          <group delimiter=". ">
            <text macro="author-bib"/>
            <text macro="year"/>
            <text variable="title"/>
            <text variable="publisher"/>
            <text variable="version" prefix="Version "/>
          </group>
          <text macro="doi-or-url" suffix="."/>
        </else-if>
        <else-if type="software" match="any">
          <group delimiter=". ">
            <text macro="author-bib"/>
            <text macro="year"/>
            <text variable="title"/>
            <text variable="version" prefix="Version "/>
            <text variable="publisher"/>
          </group>
          <text macro="doi-or-url" suffix="."/>
        </else-if>
        <else-if type="webpage post-weblog" match="any">
          <group delimiter=". ">
            <text macro="author-bib"/>
            <text macro="year"/>
            <text variable="title"/>
            <text variable="container-title"/>
          </group>
          <text macro="access" suffix="."/>
        </else-if>
        <else>
          <group delimiter=". ">
            <text macro="author-bib"/>
            <text macro="year"/>
            <text macro="title"/>
            <text variable="container-title"/>
          </group>
          <text macro="doi-or-url" suffix="."/>
        </else>
      </choose>
    </layout>
  </bibliography>
</style>
